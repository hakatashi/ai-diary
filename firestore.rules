rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'hakatasiloving@gmail.com'
        && request.auth.token.email_verified == true;
    }

    match /dataSources/{dataSourceId} {
      allow read: if isOwner();
      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enabled', 'updatedAt']);
      allow create, delete: if false;
    }

    match /dataSourceSecrets/{dataSourceId} {
      allow read, write: if false;
    }

    match /oauthStates/{state} {
      allow read, write: if false;
    }

    match /placesCache/{placeId} {
      allow read, write: if false;
    }

    match /placesApiUsage/{monthKey} {
      allow read, write: if false;
    }

    match /logEntries/{logEntryId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /journalEntries/{date} {
      allow read: if isOwner();
      allow create, update: if isOwner() && request.resource.data.date == date;
      allow delete: if false;
    }
  }
}
